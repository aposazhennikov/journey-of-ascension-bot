# Telegram Bot Configuration
BOT_TOKEN=your_bot_token_here

# Admin User IDs (comma-separated)
ADMIN_IDS=123456789,987654321

# Send "Yoga Bot Started" messages to admins on every restart
NOTIFY_ADMINS_ON_STARTUP=false

# Optional: Sentry DSN for error tracking
SENTRY_DSN=

# Optional: Data directory path
DATA_DIR=data

# Optional: HTTP server port for healthcheck
HTTP_PORT=8080

# Optional: Logging level
LOG_LEVEL=INFO

# Optional: Proxy for Telegram API requests.
# For a proxy running on the Windows host from Docker Desktop/WSL, use host.docker.internal.
# Example: TELEGRAM_PROXY_URL=http://host.docker.internal:7890
TELEGRAM_PROXY_URL=

# Optional: Environment name for Sentry
ENVIRONMENT=production
